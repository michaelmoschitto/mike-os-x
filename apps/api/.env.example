# Example environment variables for API (Backend)
# Copy this file to .env.local and fill in the values

# CORS origins - comma-separated list (REQUIRED)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Docker configuration (for local development, uses local Docker socket)
# DOCKER_HOST=unix:///var/run/docker.sock
# DOCKER_TLS_VERIFY=0

# Redis URL (optional for local, uses default if not set)
# REDIS_URL=redis://localhost:6379/0

# Admin API key (required, minimum 32 characters)
ADMIN_API_KEY=replace-with-a-strong-random-value

# Comma-separated direct proxy IPs allowed to supply X-Forwarded-For
# TRUSTED_PROXY_IPS=10.0.0.5
